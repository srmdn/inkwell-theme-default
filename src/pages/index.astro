---
import BaseLayout from '../layouts/BaseLayout.astro';
import { listPosts, getSettings, formatDate } from '../lib/content';

const [posts, settings] = await Promise.all([listPosts(), getSettings()]);
---

<BaseLayout
  title={settings.siteName}
  description={settings.siteDescription || undefined}
  settings={settings}
>
  {settings.siteDescription && (
    <p class="site-intro">{settings.siteDescription}</p>
  )}

  {posts.length === 0 ? (
    <p class="empty-state">Nothing here yet.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li class="post-list-item">
          <h2>
            <a href={`/blog/${post.slug}`}>{post.frontmatter.title}</a>
          </h2>
          <p class="post-meta">{formatDate(post.frontmatter.publishDate)}</p>
          {post.frontmatter.description && (
            <p class="post-description">{post.frontmatter.description}</p>
          )}
          {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
            <div class="tags">
              {post.frontmatter.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
