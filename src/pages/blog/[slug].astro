---
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getPost, getSettings, formatDate } from '../../lib/content';

const { slug } = Astro.params;

if (!slug) return Astro.redirect('/404');

const [post, settings] = await Promise.all([getPost(slug), getSettings()]);
if (!post) return Astro.redirect('/404');

const html = marked(post.body);
---

<BaseLayout
  title={post.frontmatter.title}
  description={post.frontmatter.description}
  settings={settings}
>
  <a href="/" class="back-link">&#8592; All posts</a>

  <article>
    <header class="post-header">
      <h1>{post.frontmatter.title}</h1>
      <p class="post-meta">
        {formatDate(post.frontmatter.publishDate)}
        {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
          <span> &middot; {post.frontmatter.tags.join(', ')}</span>
        )}
      </p>
      {post.frontmatter.heroImage && (
        <img class="post-hero" src={post.frontmatter.heroImage} alt={post.frontmatter.title} />
      )}
    </header>

    <div class="post-content" set:html={html} />
  </article>
</BaseLayout>
